# Redpanda SASL users
RP_ADMIN_USERNAME=admin
RP_ADMIN_PASSWORD=change_me_admin_password
RP_APP_USERNAME=kafka
RP_APP_PASSWORD=change_me_kafka_password

# Redpanda Console Basic Auth
CONSOLE_BASIC_AUTH_USERNAME=admin
# Generate a bcrypt/apr1 hash with scripts/generate-htpasswd.sh or docker run --rm httpd:2.4-alpine htpasswd -nbB admin your_password
CONSOLE_BASIC_AUTH_HTPASSWD=admin:$2y$05$replace_this_hash_before_use

# Host-facing ports
REDPANDA_KAFKA_INTERNAL_PORT=9092
REDPANDA_KAFKA_EXTERNAL_PORT=19092
CONSOLE_PROXY_PORT=9090
